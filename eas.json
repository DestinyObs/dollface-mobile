{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://dollface-api.onrender.com/api"
      },
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://dollface-api.onrender.com/api"
      },
      "channel": "preview"
    },
    "ios-sim": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://dollface-api.onrender.com/api"
      },
      "channel": "ios-sim"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://dollface-api.onrender.com/api"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
