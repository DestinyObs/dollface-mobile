# Mobile runtime config
# Backend base URL the app talks to (always real — no mock fallback).
# Local simulator/web on this machine:
EXPO_PUBLIC_API_URL=http://localhost:4200/api
# Physical device on same Wi-Fi (replace with your machine IP):
# EXPO_PUBLIC_API_URL=http://192.168.18.3:4200/api
# Production:
# EXPO_PUBLIC_API_URL=https://api.dollface.app/api
